#!/usr/bin/env python3
"""
Board CLI - Command-line interface for Agent Board tools.

Usage:
    board move <task_id> <column>        Move task to column
    board comment <task_id> <text>       Add comment to task
    board get <task_id>                  Get task details
    board my [status] [limit]            List my tasks

Examples:
    board move task_abc123 doing
    board comment task_abc123 "Started working on this"
    board get task_abc123
    board my todo 5
"""

import sys
import os

# Add lib directory to path
lib_dir = os.path.join(os.path.dirname(__file__), 'lib')
sys.path.insert(0, lib_dir)

try:
    from board_tools import board_move_task, board_add_comment, board_get_task, board_my_tasks
except ImportError as e:
    print(f"Error: Failed to import board tools: {e}")
    sys.exit(1)


def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)

    command = sys.argv[1].lower()

    try:
        if command == "move":
            if len(sys.argv) != 4:
                print("Usage: board move <task_id> <column>")
                sys.exit(1)
            task_id, column = sys.argv[2], sys.argv[3]
            result = board_move_task(task_id, column)
            print(result)

        elif command == "comment":
            if len(sys.argv) < 4:
                print("Usage: board comment <task_id> <text>")
                sys.exit(1)
            task_id = sys.argv[2]
            comment = " ".join(sys.argv[3:])
            result = board_add_comment(task_id, comment)
            print(result)

        elif command == "get":
            if len(sys.argv) != 3:
                print("Usage: board get <task_id>")
                sys.exit(1)
            task_id = sys.argv[2]
            result = board_get_task(task_id)
            print(result)

        elif command == "my":
            status = sys.argv[2] if len(sys.argv) > 2 else None
            limit = int(sys.argv[3]) if len(sys.argv) > 3 else 10
            result = board_my_tasks(status, limit)
            print(result)

        else:
            print(f"Unknown command: {command}")
            print(__doc__)
            sys.exit(1)

    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()